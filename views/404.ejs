<main class="main">

    <!-- Page Title -->
    <div class="page-title dark-background" data-aos="fade"
        style="background-image: url(assets/img/page-title-bg.jpg);">
        <div class="container position-relative">
            <h1>404 - Page Not Found</h1>
            <p>The page you are looking for might have been removed, had its name changed, or is temporarily
                unavailable.</p>
            <nav class="breadcrumbs">
                <ol>
                    <li><a href="/">Home</a></li>
                    <li class="current">404 Error</li>
                </ol>
            </nav>
        </div>
    </div><!-- End Page Title -->

    <!-- 404 Error Section -->
    <section id="error-404" class="starter-section section">

        <!-- Section Title -->
        <div class="container section-title" data-aos="fade-up">
            <span>404 Error<br></span>
            <h2>Page Not Found</h2>
            <p>We couldn't find the page you were looking for.</p>
        </div><!-- End Section Title -->

        <div class="container text-center" data-aos="fade-up">
            <!-- Large 404 number -->
            <div class="display-1 fw-bold text-primary mb-4"
                style="font-size: 6rem; color: var(--accent-color) !important;">404</div>
            <h3 class="mb-3">Oops! This page has gone missing.</h3>
            <p class="lead mb-4">It seems you've stumbled upon a page that doesn't exist. Don't worry, you can go back
                to the homepage or use the search to find what you need.</p>

            <!-- Optional search form (consistent with original template) -->
            <form action="/blogs" method="get" class="row g-2 justify-content-center mb-4">
                <div class="col-md-6">
                    <input type="text" name="search" class="form-control form-control-lg"
                        placeholder="Search our site...">
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-lg">Search</button>
                </div>
            </form>

            <div class="mt-3">
                <a href="/" class="btn btn-primary me-2">← Back to Home</a>
                <a href="/contact" class="btn btn-outline-secondary">Contact Support</a>
            </div>
        </div>

    </section><!-- /404 Section -->

</main>