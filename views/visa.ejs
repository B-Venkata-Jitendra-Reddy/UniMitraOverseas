  <!-- Visa Overview Section -->
  <section id="visa-overview" class="starter-section section">
    <div class="container section-title" data-aos="fade-up">
      <span>Student Visas</span>
      <h2>Study Abroad Visa Guide</h2>
      <p>Step‑by‑step information on visa types, requirements, application process, and post‑study work rights for our partner countries.</p>
    </div>

    <div class="container" data-aos="fade-up">
      <div class="row gy-4">

        <!-- United Kingdom -->
        <div class="col-lg-6">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                <i class="fas fa-passport fa-2x text-primary me-3"></i>
                <h3 class="card-title mb-0">United Kingdom</h3>
              </div>
              <h5>Student Visa (Student Route)</h5>
              <ul class="list-unstyled mt-3">
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Visa type:</strong> Student Route (formerly Tier 4)</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Duration:</strong> Course length + up to 4 months</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Financial proof:</strong> £1,334/month (London) or £1,023/month (outside)</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>English requirement:</strong> IELTS/UKVI SELT</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Work rights:</strong> Up to 20 hours/week during term</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Post-study work:</strong> Graduate Route – 2 years (3 years for PhD)</li>
              </ul>
              <a href="https://www.gov.uk/student-visa" target="_blank" class="btn btn-outline-primary btn-sm mt-2">Official Guide →</a>
            </div>
          </div>
        </div>

        <!-- United States -->
        <div class="col-lg-6">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                <i class="fas fa-passport fa-2x text-primary me-3"></i>
                <h3 class="card-title mb-0">United States</h3>
              </div>
              <h5>F-1 Student Visa</h5>
              <ul class="list-unstyled mt-3">
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Visa type:</strong> F-1 (Academic) / M-1 (Vocational)</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Duration:</strong> Duration of status (D/S) – length of study</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Financial proof:</strong> Full tuition + living expenses</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>English requirement:</strong> IELTS/TOEFL (university dependent)</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Work rights:</strong> On‑campus up to 20 hours/week; CPT/OPT allowed</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Post-study work:</strong> OPT up to 12–36 months (STEM extended)</li>
              </ul>
              <a href="https://travel.state.gov/content/travel/en/us-visas/study/student-visa.html" target="_blank" class="btn btn-outline-primary btn-sm mt-2">Official Guide →</a>
            </div>
          </div>
        </div>

        <!-- Australia -->
        <div class="col-lg-6">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                <i class="fas fa-passport fa-2x text-primary me-3"></i>
                <h3 class="card-title mb-0">Australia</h3>
              </div>
              <h5>Student Visa (subclass 500)</h5>
              <ul class="list-unstyled mt-3">
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Visa type:</strong> Student Visa (500)</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Duration:</strong> Up to 5 years (depending on course)</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Financial proof:</strong> AUD 29,710 per year</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>English requirement:</strong> IELTS 6.0 (no band below 5.5)</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Work rights:</strong> 48 hours/fortnight during term</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Post-study work:</strong> Temporary Graduate visa (485) – 2 to 4 years</li>
              </ul>
              <a href="https://immi.homeaffairs.gov.au/visas/getting-a-visa/visa-listing/student-500" target="_blank" class="btn btn-outline-primary btn-sm mt-2">Official Guide →</a>
            </div>
          </div>
        </div>

        <!-- Canada -->
        <div class="col-lg-6">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                <i class="fas fa-passport fa-2x text-primary me-3"></i>
                <h3 class="card-title mb-0">Canada</h3>
              </div>
              <h5>Study Permit</h5>
              <ul class="list-unstyled mt-3">
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Visa type:</strong> Study Permit + TRV</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Duration:</strong> Course length + 90 days</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Financial proof:</strong> CAD 20,635 + tuition fees</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>English requirement:</strong> IELTS 6.0 (no band below 5.5)</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Work rights:</strong> Up to 20 hours/week off‑campus</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Post-study work:</strong> PGWP up to 3 years</li>
              </ul>
              <a href="https://www.canada.ca/en/immigration-refugees-citizenship/services/study-canada.html" target="_blank" class="btn btn-outline-primary btn-sm mt-2">Official Guide →</a>
            </div>
          </div>
        </div>

        <!-- Germany -->
        <div class="col-lg-6">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
              <div class="d-flex align-items-center mb-3">
                <i class="fas fa-passport fa-2x text-primary me-3"></i>
                <h3 class="card-title mb-0">Germany</h3>
              </div>
              <h5>Student Visa / Student Applicant Visa</h5>
              <ul class="list-unstyled mt-3">
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Visa type:</strong> National Visa (D) for studies</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Duration:</strong> Up to 2 years (renewable)</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Financial proof:</strong> €11,904 blocked account (per year)</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>English requirement:</strong> IELTS/TOEFL (or German language, if required)</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Work rights:</strong> 120 full days / 240 half days per year</li>
                <li><i class="bi bi-check-circle-fill text-success me-2"></i> <strong>Post-study work:</strong> 18‑month job‑seeking visa → Blue Card → PR</li>
              </ul>
              <a href="https://www.germany-visa.org/student-visa/" target="_blank" class="btn btn-outline-primary btn-sm mt-2">Official Guide →</a>
            </div>
          </div>
        </div>

      </div>
